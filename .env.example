# Required: OpenAI API key
OPENAI_API_KEY=your_openai_api_key_here

# Optional: override model name
OPENAI_MODEL=gpt-4.1-mini

# Required for bioinformatics server integration
BIO_SERVER_URL=https://your-bio-hack-server.example.com

# Optional: if your bio server needs a bearer token
BIO_SERVER_API_KEY=

# Optional: port for local app
PORT=3000
