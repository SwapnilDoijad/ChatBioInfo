# Network
PORT=8787

# Required: SSH target for HPC login node
HPC_SSH_TARGET=xa73pav@login2.draco.uni-jena.de

# Required: command run inside the SLURM job script
# Placeholders: {input}, {output}, {jobDir}
HPC_ANALYSIS_COMMAND=python3 /path/to/fastqc_runner.py --input {input} --output {output} --job-dir {jobDir}

# Optional: remote work directory on shared storage
HPC_WORKDIR=~/chatbioinfo-bridge

# Optional: remote upload directory on shared storage
HPC_UPLOAD_DIR=~/chatbioinfo-bridge/uploads

# Optional: protect bridge endpoints with bearer token
# If set, requests must include: Authorization: Bearer <token>
BIO_BRIDGE_API_KEY=

# SLURM settings
SLURM_PARTITION=
SLURM_ACCOUNT=
SLURM_TIME=00:10:00
SLURM_CPUS=2
SLURM_MEM=4G
SLURM_EXTRA_DIRECTIVES=

# Polling/wait behavior for /analyze
DEFAULT_WAIT_FOR_COMPLETION=false
MAX_WAIT_SECONDS=45
POLL_INTERVAL_SECONDS=4
